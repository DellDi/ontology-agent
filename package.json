{
  "name": "ontology-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:real:analysis": "NODE_OPTIONS=--conditions=react-server npx tsx --tsconfig tsconfig.json scripts/run-real-analysis-regression.mts",
    "graph:sync:neo4j": "NODE_OPTIONS=--conditions=react-server npx tsx --tsconfig tsconfig.json scripts/sync-neo4j-bootstrap.mts",
    "graph:sync:bootstrap": "NODE_OPTIONS=--conditions=react-server npx tsx --tsconfig tsconfig.json scripts/sync-neo4j-bootstrap.mts",
    "graph:sync:org": "NODE_OPTIONS=--conditions=react-server npx tsx --tsconfig tsconfig.json scripts/sync-neo4j-org.mts",
    "graph:sync:incremental": "NODE_OPTIONS=--conditions=react-server npx tsx --tsconfig tsconfig.json scripts/sync-neo4j-incremental.mts",
    "graph:sync:dispatch": "NODE_OPTIONS=--conditions=react-server npx tsx --tsconfig tsconfig.json scripts/sync-neo4j-dispatch.mts",
    "graph:sync:consistency-sweep": "NODE_OPTIONS=--conditions=react-server npx tsx --tsconfig tsconfig.json scripts/sync-neo4j-consistency-sweep.mts",
    "graph:sync:diagnose-org": "NODE_OPTIONS=--conditions=react-server npx tsx --tsconfig tsconfig.json scripts/sync-neo4j-diagnose-org.mts",
    "graph:sync:status": "NODE_OPTIONS=--conditions=react-server npx tsx --tsconfig tsconfig.json scripts/sync-neo4j-status.mts",
    "cube:token": "node scripts/generate-cube-dev-token.mjs",
    "ontology:bootstrap": "NODE_OPTIONS=--conditions=react-server npx tsx --tsconfig tsconfig.json scripts/ontology-bootstrap.mts",
    "ontology:bootstrap:status": "NODE_OPTIONS=--conditions=react-server npx tsx --tsconfig tsconfig.json scripts/ontology-bootstrap.mts --status",
    "test:smoke:bailian": "NODE_OPTIONS=--conditions=react-server RUN_BAILIAN_SMOKE_TEST=1 npx tsx --test tests/story-4-1-bailian-smoke.test.mts",
    "test:smoke:neo4j": "NODE_OPTIONS=--conditions=react-server RUN_NEO4J_SMOKE_TEST=1 npx tsx --test tests/story-4-5-neo4j-smoke.test.mjs --no-cache",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "worker:dev": "NODE_OPTIONS=--conditions=react-server npx tsx --tsconfig tsconfig.json src/worker/main.ts"
  },
  "dependencies": {
    "ai": "^5.0.179",
    "drizzle-orm": "0.45.1",
    "mysql2": "^3.20.0",
    "neo4j-driver": "^6.0.1",
    "next": "16.2.1",
    "openai": "^6.33.0",
    "pg": "8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "^5.11.0",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/env": "16.2.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "lightningcss": "1.32.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
