APP_PORT=3000
# Database
POSTGRES_DB=ontology_agent
# Local port for Postgres (not container port)
POSTGRES_PORT=55432
POSTGRES_USER=ontology_agent
POSTGRES_PASSWORD=ontology_agent_dev_password
DATABASE_URL=postgresql://ontology_agent:ontology_agent_dev_password@127.0.0.1:55432/ontology_agent
# Redis
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379
SESSION_SECRET=replace-with-a-local-dev-session-secret
ENABLE_DEV_ERP_AUTH=0
REDIS_KEY_PREFIX=dip3
# ERP 目录认证（账号密码登录）
ERP_API_BASE_URL=http://your-erp-host/api
ENABLE_URL_BRIDGE=0
# CUBE
CUBE_PORT=4000
CUBE_API_URL=http://127.0.0.1:4000/cubejs-api/v1
CUBE_API_SECRET=replace-with-a-local-dev-cube-secret
CUBE_API_TOKEN=replace-with-a-local-dev-cube-jwt
CUBE_QUERY_TIMEOUT_MS=15000
# NEO4J
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-with-a-real-neo4j-password
NEO4J_DATABASE=neo4j
# LLM_PROVIDER
LLM_PROVIDER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=replace-with-a-real-dashscope-key
LLM_PROVIDER_MODEL=bailian/qwen3.6-plus
LLM_FALLBACK_MODELS=bailian/kimi-k2.5,bailian/MiniMax/MiniMax-M2.7,bailian/glm-5
LLM_REQUEST_TIMEOUT_MS=15000
LLM_MAX_RETRIES=2
LLM_RATE_LIMIT_MAX_REQUESTS=20
LLM_RATE_LIMIT_WINDOW_SECONDS=60
RUN_BAILIAN_SMOKE_TEST=1
