APP_PORT=3000
# Database
POSTGRES_DB=ontology_agent
# Local port for Postgres (not container port)
POSTGRES_PORT=55432
POSTGRES_USER=ontology_agent
POSTGRES_PASSWORD=ontology_agent_dev_password
DATABASE_URL=postgresql://ontology_agent:ontology_agent_dev_password@127.0.0.1:55432/ontology_agent
# Redis
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379
SESSION_SECRET=replace-with-a-local-dev-session-secret
ENABLE_DEV_ERP_AUTH=1
REDIS_KEY_PREFIX=dip3
# LLM_PROVIDER
LLM_PROVIDER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=replace-with-a-real-dashscope-key
LLM_PROVIDER_MODEL=bailian/kimi-k2.5
LLM_FALLBACK_MODELS=bailian/qwen3.5-plus,bailian/MiniMax/MiniMax-M2.7,bailian/glm-5
LLM_REQUEST_TIMEOUT_MS=15000
LLM_MAX_RETRIES=2
LLM_RATE_LIMIT_MAX_REQUESTS=20
LLM_RATE_LIMIT_WINDOW_SECONDS=60
RUN_BAILIAN_SMOKE_TEST=1
